rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // อนุญาตให้ทุกคนดูรูปสลิปได้ (Public Read)
      allow read: if true;
      // การเขียน (Upload) ควรให้เฉพาะ User ที่ Login หรือจัดการผ่าน Admin SDK (API)
      allow write: if request.auth != null; 
    }
  }
}