{
  "firestore": {
    "database": "xiong-birthday-2026",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/saveUser",
        "function": "saveUser"
      },
      {
        "source": "/saveDonate",
        "function": "saveDonate"
      },
      {
        "source": "/getDonationAll",
        "function": "getDonationAll"
      },
      {
        "source": "/getUserInfoByXid",
        "function": "getUserInfoByXid"
      },
      {
        "source": "/updateDonateStatus",
        "function": "updateDonateStatus"
      }
    ]
  }
}